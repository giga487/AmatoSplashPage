<div class="navmenu">
    <input type="checkbox" title="Menu expand/collapse toggle" id="navmenu-toggle" class="navmenu-icon" />
    <label for="navmenu-toggle" class="navmenu-icon"><FluentIcon Value="@(new Icons.Regular.Size20.Navigation())" Color="Color.Fill" /></label>
    <nav class="sitenav" aria-labelledby="main-menu">
        <FluentNavMenu Id="main-menu" Width="250" Collapsible="true" Title="Navigation menu" @bind-Expanded="expanded" CustomToggle="true">
             <FluentNavLink Href="" Match="NavLinkMatch.All" Icon="@(new Icons.Regular.Size20.Home())" IconColor="Color.Accent">Home</FluentNavLink>
             <FluentNavLink Href="cv" Icon="@(new Icons.Regular.Size20.Document())" IconColor="Color.Accent">CV</FluentNavLink>
             <FluentNavLink Href="AsciiArt" Icon="@(new Icons.Regular.Size20.Image())" IconColor="Color.Accent">Ascii Art</FluentNavLink>
             <FluentNavLink Href="bouncingballs" Icon="@(new Icons.Regular.Size20.Play())" IconColor="Color.Accent">Bouncing Balls</FluentNavLink>
             <FluentNavLink Href="space-invaders" Icon="@(new Icons.Regular.Size20.Games())" IconColor="Color.Accent">Space Invaders</FluentNavLink>
        </FluentNavMenu>
    </nav>
</div>

@code {
    private bool expanded = true;
}
