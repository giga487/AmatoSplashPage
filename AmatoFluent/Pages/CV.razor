@page "/cv"
@using AmatoFluent.Models
@inject HttpClient Http

<PageTitle>Curriculum vitae</PageTitle>

@if (cvData == null)
{
    <FluentProgressRing />
}
else
{
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="20" Style="padding: 20px;">
        
        <FluentLabel Typo="Typography.PageTitle">Pierluigi Amato</FluentLabel>
        <FluentLabel Typo="Typography.H4">Curriculum Vitae</FluentLabel>
        <FluentDivider />

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">Contact</FluentLabel>
            <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 15px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Mail())" Color="Color.Neutral" /> 
                    <a href="mailto:@cvData.Contact.Email?subject=AskSomethingViaSite" style="color: var(--accent-fill-rest); text-decoration: none;">@cvData.Contact.Email</a>
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Color="Color.Neutral" /> 
                    <a href="@cvData.Contact.LinkedIn" target="_blank" style="color: var(--accent-fill-rest); text-decoration: none;">LinkedIn Profile</a>
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Location())" Color="Color.Neutral" /> 
                    <span style="color: var(--neutral-foreground-rest);">@cvData.Contact.Location</span>
                </div>
                <div style="margin-top: 5px; display: flex; gap: 10px;">
                    <FluentAnchor Href="https://raw.githubusercontent.com/giga487/AmatoSplashPage/main/AmatoFluent/wwwroot/AmatoCV.pdf" Download="amatocv.pdf" Appearance="Appearance.Accent" Target="_blank">
                        <FluentIcon Value="@(new Icons.Regular.Size20.DocumentPdf())" Slot="start" Color="Color.Lightweight" /> Download PDF
                    </FluentAnchor>
                    <FluentAnchor Href="https://raw.githubusercontent.com/giga487/AmatoSplashPage/main/cv-data.json" Download="cv-data.json" Appearance="Appearance.Neutral">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Document())" Slot="start" Color="Color.Neutral" /> Download JSON Data
                    </FluentAnchor>
                </div>
            </div>
        </FluentCard>

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">Who am I</FluentLabel>
            <div style="margin-top: 10px; line-height: 1.6; color: var(--neutral-foreground-rest);">
                @foreach (var p in cvData.Summary)
                {
                    <p>@((MarkupString)p.Replace("**Currently**", "<strong>Currently</strong>")
                                          .Replace("[GitHub Page](https://giga487.github.io/AmatoSplashPage/)", "<a href=\"https://giga487.github.io/AmatoSplashPage/\">GitHub Page</a>"))</p>
                }
            </div>
        </FluentCard>

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">Jobs</FluentLabel>
            @foreach (var job in cvData.Jobs)
            {
                <div style="margin-top: 15px;">
                    <FluentLabel Typo="Typography.H4">@job.Title@(!string.IsNullOrEmpty(job.Company) ? $", {job.Company}" : "")</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@job.Date</FluentLabel>
                    @if (job.Tasks != null && job.Tasks.Count > 0)
                    {
                        <ul style="margin-top: 5px;">
                            @foreach (var task in job.Tasks)
                            {
                                <li>@((MarkupString)task.Replace("[SKIA 2D graphics](https://skia.org/)", "<a href=\"https://skia.org/\" target=\"_blank\">SKIA 2D graphics</a>")
                                                        .Replace("[Halcon](https://www.mvtec.com/products/halcon)", "<a href=\"https://www.mvtec.com/products/halcon\" target=\"_blank\">Halcon</a>")
                                                        .Replace("**GITHUB**", "<strong>GITHUB</strong>"))</li>
                            }
                        </ul>
                    }
                </div>
                @if (job != cvData.Jobs.Last())
                {
                    <FluentDivider Style="margin: 15px 0;" />
                }
            }
        </FluentCard>

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">Education</FluentLabel>
            <div style="margin-top: 10px;">
                @foreach(var edu in cvData.Education)
                {
                    <div style="margin-bottom: 15px;">
                        <FluentLabel Typo="Typography.H4">
                            <FluentIcon Value="@(new Icons.Regular.Size20.HatGraduation())" Style="margin-right: 5px;" Color="Color.Neutral" /> @edu.Title
                        </FluentLabel>
                        @if (!string.IsNullOrEmpty(edu.Date))
                        {
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@edu.Date</FluentLabel>
                        }
                        @if (!string.IsNullOrEmpty(edu.Description))
                        {
                            <span style="display:block; margin-top:5px;">
                                @((MarkupString)edu.Description.Replace("[here](https://ieeexplore.ieee.org/document/10016730)", "<a href=\"https://ieeexplore.ieee.org/document/10016730\" target=\"_blank\">here</a>"))
                            </span>
                        }
                    </div>
                }
            </div>
        </FluentCard>

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">University Projects</FluentLabel>
            <ul style="margin-top: 15px; line-height: 1.6;">
                @foreach(var uprog in cvData.UniversityProjects)
                {
                    <li style="margin-bottom: 10px;">
                        <strong>@uprog.Title</strong><br/>
                        @((MarkupString)uprog.Description.Replace("**railway simulator**", "<b>railway simulator</b>")
                                                         .Replace("[YouTube](https://www.youtube.com/watch?v=wL0Aum5eXEo)", "<a href=\"https://www.youtube.com/watch?v=wL0Aum5eXEo\" target=\"_blank\">YouTube video</a>"))
                    </li>
                }
            </ul>
        </FluentCard>

        <FluentCard AreaRestricted="false">
            <FluentLabel Typo="Typography.H2" Weight="FontWeight.Bold">Personal Projects</FluentLabel>
            <ul style="margin-top: 15px; line-height: 1.6;">
                @foreach(var proj in cvData.Projects)
                {
                    <li style="margin-bottom: 10px;">
                        <strong>@proj.Title:</strong> 
                        @((MarkupString)proj.Description.Replace("[giga487](https://github.com/giga487)", "<a href=\"https://github.com/giga487\" target=\"_blank\">giga487</a>"))
                        @if (proj.Tasks != null && proj.Tasks.Count > 0)
                        {
                            <ul>
                                @foreach(var task in proj.Tasks)
                                {
                                    <li>@task</li>
                                }
                            </ul>
                        }
                    </li>
                }
            </ul>
        </FluentCard>
    </FluentStack>
}

@code {
    private CvData? cvData;

    protected override async Task OnInitializedAsync()
    {
        // Load the CV structured Data from JSON Source of truth.
        cvData = await Http.GetFromJsonAsync<CvData>("sample-data/cv-data.json");
    }
}

